*.DS_Store

# Emacs generated
sources/opt/emacs/.emacs.d/saves/
sources/opt/emacs/.emacs.d/custom.el
sources/opt/emacs/.emacs.d/elpa/

# Fish generated (keep config.fish and functions)
sources/opt/fish/.config/fish/*
!sources/opt/fish/.config/fish/config.fish
!sources/opt/fish/.config/fish/functions/

# Kitty generated themes
sources/opt/kitty/.config/kitty/theme.conf
sources/opt/kitty/.config/kitty/kitty-themes/

# Kakoune plugins
sources/opt/kakoune/.config/kak/plugins/

# Xmonad compiled binary (keep source)
sources/linux/xmonad/.xmonad/*
!sources/linux/xmonad/.xmonad/xmonad.hs
!sources/linux/xmonad/.xmonad/xmobarrc

# Clojure cache
sources/core/clojure/.clojure/.cpcache/
