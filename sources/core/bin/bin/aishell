#!/usr/bin/env zsh

function _aishell_copy() {
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$1" | pbcopy
  elif command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$1" | wl-copy
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$1" | xclip -selection clipboard
  else
    echo "aishell: no clipboard tool found (pbcopy/wl-copy/xclip)" >&2
    return 1
  fi
  echo "copied."
}

function _aishell_generate() {
  local prompt="$1"
  local raw cmd

  local system_prompt="You are a shell command generator. Respond with ONLY a JSON object on a single line: {\"command\": \"<the command>\"} — no markdown, no code fences, no commentary.

Rules for the command value:
- Valid runnable $shell_name syntax for $os_name with standard Unix tools.
- A single command line (chain with ; && or | as needed). Use \n escape sequences inside strings — never literal newlines.

Example input: find the 5 largest files in current directory
Example output: {\"command\": \"find . -type f -exec du -sh {} + | sort -rh | head -5\"}"

  raw=$(pi --provider "$provider" --model "$model" \
    --print --no-tools --thinking "$thinking" --no-session \
    --system-prompt "$system_prompt" \
    "$prompt" </dev/null)

  # Trim whitespace, then strip code fences in case the model leaks them anyway
  raw="$(printf '%s' "$raw" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
  raw="${raw#\`\`\`}"
  raw="${raw%\`\`\`}"
  local first_word="${raw%%[[:space:]]*}"
  case "$first_word" in
    json|sh|bash|zsh|shell) raw="${raw#$first_word}"; raw="${raw# }" ;;
  esac

  cmd=$(printf '%s' "$raw" | jq -r '.command // empty' 2>/dev/null)

  # Fallback: model didn't return valid JSON — treat the raw text as the command
  if [[ -z "$cmd" ]]; then
    cmd="$raw"
    [[ "$cmd" == "\`"*"\`" ]] && cmd="${cmd#\`}" && cmd="${cmd%\`}"
  fi

  # Final cleanup: remove \r, collapse lines to spaces, trim
  cmd="$(printf '%s' "$cmd" | tr -d '\r' | tr '\n' ' ' | sed 's/[[:space:]]\{2,\}/ /g; s/^[[:space:]]*//; s/[[:space:]]*$//')"
  printf '%s\n' "$cmd"
}

function _aishell_usage() {
  echo "Usage: aishell (-c|-q) [-p|--pro] [-t] [--provider <name>] <prompt...>"
  echo ""
  echo "  -c          Command generation mode — outputs one shell command"
  echo "  -q          Question mode — answers a question using AI"
  echo "  -p, --pro   Use DeepSeek V4 Pro (default: DeepSeek v4 Flash)"
  echo "  -t          Enable thinking (default: off)"
  echo "  --provider  Provider to use (default: openrouter)"
}

local provider="openrouter"
local model="deepseek/deepseek-v4-flash"
local mode=""
local thinking="off"

local shell_name="$(basename "$SHELL")"
local os_name
case "$(uname)" in
  Darwin) os_name="macOS" ;;
  Linux)  os_name="Linux" ;;
  *)      os_name="$(uname)" ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --provider) provider="$2"; shift 2 ;;
    -p|--pro)   model="deepseek/deepseek-v4-pro"; shift ;;
    -t)         thinking="on"; shift ;;
    -c)         mode="command"; shift ;;
    -q)         mode="question"; shift ;;
    -h|--help)  mode="help"; shift ;;
    --)         shift; break ;;
    -*)         echo "aishell: unknown flag $1" >&2; exit 1 ;;
    *)          break ;;
  esac
done

if [[ "$mode" == "help" ]]; then
  _aishell_usage
  exit 0
elif [[ -z "$mode" ]]; then
  _aishell_usage >&2
  exit 1
fi

local prompt="$*"

if [[ -z "$prompt" ]]; then
  echo "aishell: prompt required after flags" >&2
  exit 1
fi

if [[ "$mode" == "command" ]]; then
  local original_prompt="$prompt"
  local feedback=""
  local error_text=""
  local last_rc=0
  local command=""
  local pi_prompt=""
  local response=""
  local next=""
  local errfile=""
  local rc=0

  local state="generate"

  while [[ "$state" != "done" ]]; do
    if [[ "$state" == "generate" ]]; then
      if [[ -n "$error_text" ]]; then
        pi_prompt="The following shell command failed on $os_name $shell_name with exit code $last_rc:"$'\n'$'\n'"Failed command: $command"$'\n'"Error output:"$'\n'"$error_text"$'\n'$'\n'"Original request: $original_prompt"$'\n'$'\n'"Generate a corrected version. Respond in the same JSON format: {\"command\": \"...\"}."
        error_text=""
      elif [[ -n "$feedback" ]]; then
        pi_prompt="Original request: $original_prompt"$'\n'"Previous suggestion: $command"$'\n'"Correction: $feedback"
        feedback=""
      else
        pi_prompt="$original_prompt"
      fi

      command=$(_aishell_generate "$pi_prompt")
      if [[ -z "$command" ]]; then
        echo "aishell: failed to generate command" >&2
        exit 1
      fi
      printf '%s\n' "$command"
      echo -n "> [enter/y=run | c=copy | n=cancel | feedback]: "
      # Default to cancel if there's no TTY input — never eval without confirmation
      read -r response || response=n
      echo

      case "$response" in
        ""|[yY]) state="run" ;;
        [cC])    _aishell_copy "$command"; state="done" ;;
        [nN])    state="done" ;;
        *)       feedback="$response" ;;
      esac

    elif [[ "$state" == "run" ]]; then
      errfile=$(mktemp -t aishell-err.XXXXXX)
      rc=0
      # tee stderr: show it live AND keep a copy for the autofix prompt
      eval "$command" 2> >(tee "$errfile" >&2) || rc=$?

      if [[ $rc -eq 0 ]]; then
        rm -f "$errfile"
        state="done"
        continue
      fi

      last_rc=$rc
      error_text=$(<"$errfile")
      rm -f "$errfile"

      echo "✗ failed with exit code $rc"
      next=""
      while [[ -z "$next" ]]; do
        echo -n "> [enter/y=rerun | f=autofix | c=copy | n=cancel]: "
        read -r response || response=n
        echo

        case "$response" in
          ""|[yY]) next="run" ;;
          [fF])    next="generate" ;;
          [cC])    _aishell_copy "$command"; next="done" ;;
          [nN])    next="done" ;;
          *)       echo "aishell: unrecognized input: $response" >&2 ;;
        esac
      done
      state="$next"
    fi
  done
elif [[ "$mode" == "question" ]]; then
  pi --provider "$provider" --model "$model" \
    --print --thinking "$thinking" \
    --system-prompt "You are a helpful, concise assistant running in a $os_name terminal. Answer clearly and accurately. You can read files from disk and search the web — use those when you need current or file-specific information." \
    --tools "read,web_search,url_extract,web_fetch,batch_web_fetch" \
    "$prompt"
else
  echo "aishell: unknown mode $mode"
  exit 1
fi
